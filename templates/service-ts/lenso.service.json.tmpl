{
  "protocol": "lenso.service.v1",
  "name": "{{service_name}}",
  "version": "0.1.0",
  "provider": {
    "name": "{{service_name}}",
    "summary": "{{service_label}} provider"
  },
  "compatibility": {
    "remoteProtocolVersion": "1",
    "requiredHostFeatures": ["service.status"]
  },
  "install": {
    "services": [
      {
        "name": "{{service_name}}",
        "command": "pnpm start",
        "cwd": {{service_cwd}},
        "readyUrl": "http://127.0.0.1:4100/lenso/service/v1/status",
        "autoStart": true,
        "readyTimeoutMs": 10000
      }
    ]
  },
  "modules": [
    {
      "name": "{{module_name}}",
      "version": "0.1.0",
      "capabilities": ["{{module_name}}.read"]
    }
  ]
}
