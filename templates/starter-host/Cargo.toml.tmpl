[workspace]

[package]
name = "lenso-starter-host"
version = "0.1.0"
edition = "2024"
publish = false
rust-version = "1.94"

[[bin]]
name = "api"
path = "src/bin/api.rs"

[[bin]]
name = "worker"
path = "src/bin/worker.rs"

[[bin]]
name = "migrate"
path = "src/bin/migrate.rs"

[dependencies]
anyhow = "1.0"
axum = "0.8"
lenso-host = { git = "https://github.com/LioRael/lenso", rev = "6b2f4dfc1b839c17f640bdd1c4e4c5310eb8f5e3", package = "lenso-host" }
serde = { version = "1.0", features = ["derive"] }
sqlx = { version = "0.9", default-features = false, features = ["runtime-tokio", "tls-rustls-ring-webpki", "postgres"] }
tokio = { version = "1.52", features = ["macros", "rt-multi-thread"] }
utoipa = "5.5"
