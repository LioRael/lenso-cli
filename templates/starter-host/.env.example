APP_ENV=local
SERVICE_NAME=lenso-starter
LENSO_COMPOSITION_PROFILE=demo
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgres://lenso:lenso@localhost:${POSTGRES_HOST_PORT}/lenso
DATABASE_MAX_CONNECTIONS=10
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177
RUST_LOG=info,lenso=debug
LOG_FORMAT=compact
# REMOTE_MODULES=hello-action=http://127.0.0.1:4100/lenso/module/v1

# Enable the built-in OIDC provider before using Runtime Console sign-in.
# Keep JSON values wrapped in single quotes so dotenv preserves the inner
# double quotes.
# LENSO_MODULE_AUTH_OIDC__ENABLED=true
# LENSO_MODULE_AUTH_OIDC__ISSUER=http://127.0.0.1:3000
# LENSO_MODULE_AUTH_OIDC__CONSOLE_REDIRECT_URIS='["http://127.0.0.1:3000/console/oidc/callback"]'
# LENSO_MODULE_AUTH_OIDC__JWKS='{"keys":[{"alg":"RS256","e":"AQAB","kid":"console-key","kty":"RSA","n":"...","use":"sig"}]}'
# LENSO_MODULE_AUTH_OIDC__ID_TOKEN_PRIVATE_KEY_PEM=<rsa-private-key-pem>
# LENSO_MODULE_AUTH_OIDC__ID_TOKEN_KEY_ID=console-key
